<UserControl x:Class="MucLucHoSo.App.Views.Step1SourceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.05*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="1.25*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== CỘT TRÁI ===== -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Nguồn dữ liệu -->
            <Border Grid.Row="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="76"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Nguồn dữ liệu" Style="{StaticResource H2}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Định dạng:" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <RadioButton Content="xlsx" Margin="0,0,16,0" VerticalAlignment="Center"
                                     IsChecked="{Binding S.SourceKind, Converter={StaticResource EnumEquals}, ConverterParameter=Xlsx}"/>
                        <RadioButton Content="xlsb" Margin="0,0,16,0" VerticalAlignment="Center"
                                     IsChecked="{Binding S.SourceKind, Converter={StaticResource EnumEquals}, ConverterParameter=Xlsb}"/>
                        <RadioButton Content="csv" VerticalAlignment="Center"
                                     IsChecked="{Binding S.SourceKind, Converter={StaticResource EnumEquals}, ConverterParameter=Csv}"/>
                        <Border Width="1" Background="{StaticResource Line}" Margin="16,2,14,2"/>
                        <TextBlock Text="Số dòng đọc:" VerticalAlignment="Center" Foreground="{StaticResource Muted}" Margin="0,0,8,0"/>
                        <TextBox Text="{Binding RowLimitText, UpdateSourceTrigger=PropertyChanged}" Width="72" VerticalContentAlignment="Center"
                                 ToolTip="Số dòng đọc từ file (mặc định 100). Nếu lớn hơn số dòng thật thì đọc hết."/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tệp:" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <Grid Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding S.SourcePath, Mode=OneWay}" IsReadOnly="True" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Duyệt…" Style="{StaticResource GhostButton}" Command="{Binding BrowseSourceCommand}"/>
                    </Grid>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Sheet:" VerticalAlignment="Center" Margin="0,0,0,8"/>
                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox Width="230" ItemsSource="{Binding S.AvailableSheets}" SelectedItem="{Binding S.SheetName}"/>
                        <TextBlock Text="Header là dòng:" VerticalAlignment="Center" Foreground="{StaticResource Muted}" Margin="16,0,8,0"/>
                        <TextBox Text="{Binding ReadFromText, UpdateSourceTrigger=PropertyChanged}" Width="64" VerticalContentAlignment="Center"
                                 ToolTip="Số dòng Excel của dòng tiêu đề — nhập đúng số dòng thấy trong Excel (đọc thẳng dòng đó, không bỏ dòng trống). Dữ liệu đọc từ dòng kế tiếp. Mặc định 1."/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Đọc dữ liệu" Width="130" Style="{StaticResource TealButton}" Command="{Binding ReadDataCommand}"/>
                        <ProgressBar Width="70" Height="6" IsIndeterminate="True" Margin="10,0,0,0" VerticalAlignment="Center"
                                     Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}"/>
                        <TextBlock Text="{Binding ReadInfoText}" VerticalAlignment="Center" Margin="10,0,0,0"
                                   Foreground="{StaticResource Ok}" FontWeight="SemiBold"
                                   Visibility="{Binding HasReadInfo, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>

                    <!-- Gợi ý giá trị dòng dữ liệu đầu tiên: căn trái thẳng nhãn "Sheet:"; giá trị in đậm, gói 1 dòng, tràn tự "…" -->
                    <TextBlock Grid.Row="5" Grid.ColumnSpan="2" Margin="0,0,0,9"
                               TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                               LineHeight="18" LineStackingStrategy="BlockLineHeight" MaxHeight="38"
                               Foreground="{StaticResource Muted}"
                               Visibility="{Binding HasFirstRowPreview, Converter={StaticResource BoolToVis}}">
                        <Run Text="{Binding FirstRowPreviewLabel}"/><Run Text="{Binding FirstRowPreviewText}" FontWeight="Bold"/>
                    </TextBlock>

                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding StatusText}" TextWrapping="Wrap" Margin="0,2,0,10"
                               Visibility="{Binding HasStatus, Converter={StaticResource BoolToVis}}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusIsOk}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource Ok}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <Border Grid.Row="7" Grid.ColumnSpan="2" Height="1" Background="{StaticResource Line}" Margin="0,4,0,4"/>

                    <CheckBox Grid.Row="8" Grid.ColumnSpan="2" IsChecked="{Binding S.UseCsvCache}">
                        <TextBlock><Run Text="Dùng CSV Cache"/><Run Text=" — tăng tốc các lần chạy sau" Foreground="{StaticResource Muted}"/></TextBlock>
                    </CheckBox>
                </Grid>
            </Border>

            <!-- Template -->
            <Border Grid.Row="2" Style="{StaticResource Card}">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="Mẫu template" Style="{StaticResource H2}"/>
                    <!-- Chọn mẫu: dòng cuối ComboBox "➕ Import DOCX…" mở dialog (thay nút Import rời) -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="76"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="1">
                            <ComboBox ItemsSource="{Binding Templates}" SelectedItem="{Binding SelectedTemplate}"/>
                            <TextBlock Text="Chưa chọn mẫu" Foreground="{StaticResource Muted}" Margin="9,0,0,0"
                                       VerticalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="{Binding SelectedTemplate, Converter={StaticResource NullToVis}, ConverterParameter=invert}"/>
                        </Grid>
                    </Grid>

                    <!-- Chỉ hiện khi import mẫu mới -->
                    <TextBlock DockPanel.Dock="Top" Margin="76,0,0,12" TextWrapping="Wrap"
                               Text="{Binding UsingTemplateText, Mode=OneWay}"
                               Foreground="{StaticResource Accent}" FontWeight="SemiBold"
                               Visibility="{Binding IsImportedTemplate, Converter={StaticResource BoolToVis}}"/>

                    <!-- Cảnh báo trùng tên token {image…} và Alt Text ảnh -->
                    <Border DockPanel.Dock="Top" Background="#FFFDF3E6" CornerRadius="6" Padding="10,7" Margin="0,0,0,10"
                            Visibility="{Binding TemplateWarning, Converter={StaticResource NullToVis}}">
                        <TextBlock Text="{Binding TemplateWarning}" Foreground="{StaticResource Warn}" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </Border>

                    <!-- Vùng biến: 3 trạng thái chồng nhau, mỗi lúc chỉ 1 hiện -->
                    <Grid>
                        <!-- (a) Chưa chọn mẫu -->
                        <TextBlock Text="Hãy chọn mẫu để tiếp tục" Style="{StaticResource H2}"
                                   Foreground="{StaticResource Accent}" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                                   Visibility="{Binding ShowEmptyPrompt, Converter={StaticResource BoolToVis}}"/>

                        <!-- (b) Chọn mẫu nhưng không có biến dữ liệu -->
                        <TextBlock Text="Mẫu này không có biến, hãy chọn lại !" Style="{StaticResource H2}"
                                   Foreground="{StaticResource Warn}" TextWrapping="Wrap"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"
                                   Visibility="{Binding ShowNoVarWarning, Converter={StaticResource BoolToVis}}"/>

                        <!-- (c) Chọn mẫu có biến → danh sách token -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      Visibility="{Binding ShowVarLists, Converter={StaticResource BoolToVis}}">
                        <StackPanel>
                            <TextBlock Text="Biến tự do:" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <ItemsControl ItemsSource="{Binding FreeVars}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate>
                                    <Border Style="{StaticResource VarChip}"><TextBlock Text="{Binding StringFormat={}{{{0}}}}" FontFamily="Consolas" FontSize="13.5" Foreground="{StaticResource Accent}"/></Border>
                                </DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <ItemsControl ItemsSource="{Binding AutoVars}" Margin="0,0,0,8">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate>
                                    <Border Style="{StaticResource VarChip}" Background="#FFEBF7EF"><TextBlock Text="{Binding StringFormat={}{{{0}}}}" FontFamily="Consolas" FontSize="13.5" Foreground="{StaticResource Ok}"/></Border>
                                </DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Margin="0,4,0,6"><Run Text="Biến trong bảng:" FontWeight="SemiBold"/><Run Text=" (tự lặp theo từng văn bản của hồ sơ)" Foreground="{StaticResource Muted}" FontSize="13"/></TextBlock>
                            <ItemsControl ItemsSource="{Binding TableVars}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate>
                                    <Border Style="{StaticResource VarChip}" Background="#FFF2EEFC"><TextBlock Text="{Binding StringFormat={}{{{0}}}}" FontFamily="Consolas" FontSize="13.5" Foreground="#FF7A3FF2"/></Border>
                                </DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Visibility="{Binding HasImageVars, Converter={StaticResource BoolToVis}}">
                                <TextBlock Margin="0,8,0,6"><Run Text="Biến ảnh:" FontWeight="SemiBold"/><Run Text=" (ảnh Alt Text hoặc token {image…} — đường dẫn duyệt ở Bước 2)" Foreground="{StaticResource Muted}" FontSize="13"/></TextBlock>
                                <ItemsControl ItemsSource="{Binding ImageVars}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate>
                                        <Border Style="{StaticResource VarChip}" Background="#FFFBEBD2"><TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="13.5" Foreground="#FFB26A00"/></Border>
                                    </DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ===== CỘT PHẢI: Xem nhanh ===== -->
        <Border Grid.Column="2" Style="{StaticResource Card}" Padding="14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Margin="0,0,0,10" TextWrapping="Wrap">
                    <Run Text="{Binding PreviewTitle, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Accent}"/>
                </TextBlock>
                <Border BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="6" ClipToBounds="True">
                    <Grid Background="#FF6B7280">
                        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding PreviewPages}">
                                <ItemsControl.ItemTemplate><DataTemplate>
                                    <Border Background="White" Margin="12" SnapsToDevicePixels="True" HorizontalAlignment="Stretch">
                                        <Image Source="{Binding}" Stretch="Uniform"/>
                                    </Border>
                                </DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <Border Background="#FF6B7280" Visibility="{Binding HasPreview, Converter={StaticResource InverseBoolToVis}}">
                            <TextBlock Text="{Binding PreviewHint}" Foreground="White" TextWrapping="Wrap"
                                       Margin="30" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                        </Border>
                        <ProgressBar Height="6" IsIndeterminate="True" VerticalAlignment="Top"
                                     Visibility="{Binding PreviewBusy, Converter={StaticResource BoolToVis}}"/>
                    </Grid>
                </Border>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
