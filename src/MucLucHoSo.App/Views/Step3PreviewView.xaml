<UserControl x:Class="MucLucHoSo.App.Views.Step3PreviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Thanh công cụ: chia 2 cột trùng với vùng bên dưới -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="14,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="320"/>
                </Grid.ColumnDefinitions>

                <!-- Toolbar phía trên khung Preview -->
                <Grid Grid.Column="0">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <RadioButton Style="{StaticResource TextToggle}" Content="Template" Margin="0,0,16,0"
                                     IsChecked="{Binding ShowFilled, Converter={StaticResource InverseBool}}"/>
                        <RadioButton Style="{StaticResource TextToggle}" Content="Xem trước" Margin="0,0,16,0" IsChecked="{Binding ShowFilled}"/>
                        <Border Width="1" Background="{StaticResource Line}" Margin="0,3,16,3"/>
                        <Button Content="−" Style="{StaticResource GhostButton}" Padding="0" Width="36" Command="{Binding ZoomOutCommand}"
                                ToolTip="Thu nhỏ (Ctrl −, hoặc Ctrl + lăn chuột)" AutomationProperties.Name="Thu nhỏ"/>
                        <Button Style="{StaticResource LinkButton}" Content="{Binding ZoomText}" MinWidth="52" Command="{Binding ZoomResetCommand}"
                                ToolTip="Về 100% (Ctrl 0)" AutomationProperties.Name="Đặt lại zoom 100%"/>
                        <Button Content="+" Style="{StaticResource GhostButton}" Padding="0" Width="36" Command="{Binding ZoomInCommand}"
                                ToolTip="Phóng to (Ctrl +, hoặc Ctrl + lăn chuột)" AutomationProperties.Name="Phóng to"/>
                        <Border Width="1" Background="{StaticResource Line}" Margin="16,3,14,3"/>
                        <!-- Cụm Tiến/Lùi + ô tên (gõ + Enter để nhảy đến hồ sơ) -->
                        <Button Content="◀" Style="{StaticResource GhostButton}" Padding="0" Width="32" Command="{Binding PrevCommand}"
                                ToolTip="Hồ sơ trước (Ctrl ←)" AutomationProperties.Name="Hồ sơ trước"/>
                        <TextBox Text="{Binding JumpText, UpdateSourceTrigger=PropertyChanged}" Width="150" Margin="6,0" Height="32"
                                 Background="#FFEFF3FA" TextAlignment="Center" FontWeight="SemiBold" VerticalContentAlignment="Center"
                                 ToolTip="Gõ giá trị cột gom nhóm rồi Enter để nhảy đến hồ sơ">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding JumpCommand}"/>
                            </TextBox.InputBindings>
                        </TextBox>
                        <Button Content="▶" Style="{StaticResource GhostButton}" Padding="0" Width="32" Command="{Binding NextCommand}"
                                ToolTip="Hồ sơ sau (Ctrl →)" AutomationProperties.Name="Hồ sơ sau"/>
                        <TextBlock Text="{Binding NavText}" VerticalAlignment="Center" Margin="10,0,4,0" Foreground="{StaticResource Muted}"/>
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="{StaticResource Warn}" VerticalAlignment="Center"
                                   Visibility="{Binding HasMoreThanPreview, Converter={StaticResource BoolToVis}}"
                                   ToolTip="Thay đổi số lượng dòng đọc ở màn input"/>
                    </StackPanel>

                    <!-- Nút Tạo file (bên phải) — mở hộp thoại giữa màn hình bên dưới -->
                    <Button Content="Tạo file" Style="{StaticResource TealButton}"
                            HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0"
                            Command="{Binding OpenCreatePopupCommand}"/>
                </Grid>

                <!-- Tiêu đề sidebar: ngang hàng với thanh zoom -->
                <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0" TextTrimming="CharacterEllipsis">
                    <Run Text="Biến của mẫu · " FontWeight="SemiBold"/>
                    <Run Text="{Binding TemplateName, Mode=OneWay}" FontWeight="SemiBold" Foreground="{StaticResource Ink}"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Nội dung -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="320"/>
            </Grid.ColumnDefinitions>

            <!-- Khung Preview -->
            <Grid Grid.Column="0" Background="#FFEDEDED">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding PreviewPages}" HorizontalAlignment="Center">
                        <ItemsControl.LayoutTransform>
                            <ScaleTransform ScaleX="{Binding ZoomFactor}" ScaleY="{Binding ZoomFactor}"/>
                        </ItemsControl.LayoutTransform>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" Margin="14" SnapsToDevicePixels="True">
                                    <Image Source="{Binding}" Stretch="Uniform"/>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <Border Background="#FFEDEDED" Visibility="{Binding HasPreview, Converter={StaticResource InverseBoolToVis}}">
                    <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource Muted}" TextWrapping="Wrap"
                               Margin="30" VerticalAlignment="Center" HorizontalAlignment="Center" TextAlignment="Center"/>
                </Border>
                <ProgressBar Height="6" IsIndeterminate="True" VerticalAlignment="Top"
                             Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}"/>
            </Grid>

            <!-- Sidebar biến (tiêu đề đã đưa lên toolbar) -->
            <Border Grid.Column="1" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="1,0,0,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <StackPanel>
                        <!-- Cảnh báo thiếu Word: chỉ mất Preview/PDF, vẫn xuất DOCX (không chặn Tiếp theo) -->
                        <Border Background="#FFFDF3E6" CornerRadius="6" Padding="10,7" Margin="0,0,0,14"
                                Visibility="{Binding WordAvailable, Converter={StaticResource InverseBoolToVis}}">
                            <TextBlock Foreground="{StaticResource Warn}" FontWeight="SemiBold" TextWrapping="Wrap"
                                       Text="Không có Microsoft Word — chỉ xuất được DOCX, không Preview/PDF."/>
                        </Border>

                        <TextBlock TextWrapping="Wrap" Foreground="{StaticResource Muted}" FontSize="13" Margin="0,0,0,14">
                            Bấm một biến để <Run Text="nổi sáng" FontWeight="SemiBold"/> giá trị của biến đó trên trang
                            (biến trong bảng sẽ sáng cả cột). Bấm lại để tắt.
                        </TextBlock>

                        <TextBlock Text="Biến tự do" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Muted}" Margin="0,0,0,6"/>
                        <ItemsControl ItemsSource="{Binding HeaderVars}">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Button Style="{StaticResource ChipButton}" Content="{Binding}" ContentStringFormat="{}{{{0}}}"
                                        Command="{Binding DataContext.SelectVarCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <!-- Biến trang tự động (trang_so/tong_so_trang) gộp chung nhóm Biến tự do như Màn 1 -->
                        <StackPanel Visibility="{Binding HasAutoVars, Converter={StaticResource BoolToVis}}" Margin="0,0,0,4">
                            <ItemsControl ItemsSource="{Binding AutoVars}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate>
                                    <Border Background="#FFEBF7EF" CornerRadius="4" Padding="9,4" Margin="0,0,7,7"><TextBlock Text="{Binding StringFormat={}{{{0}}}}" FontFamily="Consolas" FontSize="13.5" Foreground="{StaticResource OkText}"/></Border>
                                </DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                            <TextBlock Text="{}{trang_so}/{tong_so_trang}: số trang / tổng số trang — tự động khi xuất."
                                       Foreground="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>

                        <TextBlock Margin="0,10,0,6"><Run Text="Biến trong bảng" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Muted}"/><Run Text=" (bấm để sáng cả cột)" FontSize="11.5" Foreground="{StaticResource Muted}"/></TextBlock>
                        <ItemsControl ItemsSource="{Binding RowVars}" Margin="0,0,0,14">
                            <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Button Style="{StaticResource ChipButton}" Tag="purple" Content="{Binding}" ContentStringFormat="{}{{{0}}}"
                                        Command="{Binding DataContext.SelectVarCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                        CommandParameter="{Binding}"/>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Nhóm Biến ảnh (chip cam, hiển thị-only) — giống Màn 1 -->
                        <StackPanel Visibility="{Binding HasImageVars, Converter={StaticResource BoolToVis}}">
                            <TextBlock Margin="0,0,0,6"><Run Text="Biến ảnh" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource Muted}"/><Run Text=" (ảnh Alt Text hoặc token {image…})" FontSize="11.5" Foreground="{StaticResource Muted}"/></TextBlock>
                            <ItemsControl ItemsSource="{Binding ImageVars}">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate>
                                    <Border Background="#FFFBEBD2" CornerRadius="4" Padding="9,4" Margin="0,0,7,7"><TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="13.5" Foreground="#FFB26A00"/></Border>
                                </DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Hộp thoại "Tạo file" giữa màn hình (overlay) -->
        <Grid Grid.RowSpan="2" Background="#66000000" Panel.ZIndex="10"
              Visibility="{Binding IsCreatePopupOpen, Converter={StaticResource BoolToVis}}">
            <Border Background="White" CornerRadius="10" Padding="20" MinWidth="400" MaxWidth="480"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border.Effect><DropShadowEffect BlurRadius="24" ShadowDepth="3" Opacity="0.3" Color="#FF000000"/></Border.Effect>
                <StackPanel>
                    <TextBlock Text="Tạo file cho hồ sơ đang xem" Style="{StaticResource H2}"/>
                    <!-- Trước khi tạo -->
                    <StackPanel Visibility="{Binding CreateDone, Converter={StaticResource InverseBoolToVis}}">
                        <CheckBox Content="Tạo kèm PDF (cần Microsoft Word)" IsChecked="{Binding ExportPdfChecked}"
                                  IsEnabled="{Binding WordAvailable}" Margin="0,0,0,10"/>
                        <TextBlock Text="Lưu vào:" Foreground="{StaticResource Muted}" FontSize="12.5"/>
                        <Grid Margin="0,2,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding ExportDirText}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="Đổi…" Style="{StaticResource GhostButton}" Padding="10,4" MinHeight="0" Command="{Binding ChangeExportDirCommand}"/>
                        </Grid>
                        <Border Background="{StaticResource Panel}" CornerRadius="6" Padding="10,8">
                            <StackPanel>
                                <TextBlock FontFamily="Consolas" FontSize="13"><Run Text="DOCX: " Foreground="{StaticResource Muted}"/><Run Text="{Binding ExportDocxName, Mode=OneWay}" FontWeight="SemiBold"/></TextBlock>
                                <TextBlock FontFamily="Consolas" FontSize="13" Margin="0,3,0,0"
                                           Visibility="{Binding ExportPdfChecked, Converter={StaticResource BoolToVis}}"><Run Text="PDF : " Foreground="{StaticResource Muted}"/><Run Text="{Binding ExportPdfName, Mode=OneWay}" FontWeight="SemiBold"/></TextBlock>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                    <!-- Sau khi tạo xong -->
                    <TextBlock Text="{Binding CreateResult}" TextWrapping="Wrap" Foreground="{StaticResource Ok}" FontWeight="SemiBold" Margin="0,4,0,0"
                               Visibility="{Binding CreateDone, Converter={StaticResource BoolToVis}}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Content="Đóng" Style="{StaticResource GhostButton}" Command="{Binding CloseCreatePopupCommand}"/>
                        <Button Content="Tạo file" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Command="{Binding CreateFileCommand}"
                                Visibility="{Binding CreateDone, Converter={StaticResource InverseBoolToVis}}"/>
                        <Button Content="Mở thư mục" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0" Command="{Binding OpenCreatedFolderCommand}"
                                Visibility="{Binding CreateDone, Converter={StaticResource BoolToVis}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
