<UserControl x:Class="MucLucHoSo.App.Views.Step4GenerateView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Hàng thẻ trên -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.6*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Thư mục & tên file -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="76"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="2" Text="Thư mục &amp; tên file xuất" Style="{StaticResource H2}" Margin="0,0,0,12"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Thư mục:" VerticalAlignment="Center" Margin="0,0,0,10"/>
                    <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{Binding S.OutputDirectory}" VerticalContentAlignment="Center" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Duyệt…" Style="{StaticResource GhostButton}" Command="{Binding BrowseOutputCommand}"/>
                    </Grid>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tên file:" VerticalAlignment="Top" Margin="0,6,0,10"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal">
                            <TextBox Text="{Binding S.FileNamePrefix, UpdateSourceTrigger=PropertyChanged}" Width="110" VerticalContentAlignment="Center"/>
                            <Border Background="#FFEDF2FB" CornerRadius="4" Padding="8,3" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="+ Biến gom nhóm" Foreground="{StaticResource Accent}" FontSize="12.5" FontWeight="SemiBold"/>
                            </Border>
                            <TextBlock Text="{Binding FileNamePreview}" FontWeight="SemiBold" Foreground="{StaticResource Ink}" VerticalAlignment="Center" Margin="12,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="Tự thêm số thứ tự (_2, _3…) khi trùng tên hoặc cột gom nhóm rỗng." Foreground="{StaticResource Muted}" FontSize="12.5" Margin="0,5,0,0" TextWrapping="Wrap"/>
                    </StackPanel>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Định dạng:" VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal">
                        <CheckBox IsChecked="True" IsEnabled="False" Margin="0,0,18,0" VerticalAlignment="Center">
                            <TextBlock><Run Text="DOCX" FontWeight="SemiBold" Foreground="{StaticResource Accent}"/><Run Text=" (mặc định)" Foreground="{StaticResource Muted}"/></TextBlock>
                        </CheckBox>
                        <CheckBox Content="PDF" IsChecked="{Binding S.ExportPdf}" Margin="0,0,18,0" VerticalAlignment="Center"/>
                        <CheckBox Content="Ghi đè file đã tồn tại" IsChecked="{Binding S.Overwrite}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Tùy chọn chạy -->
            <Border Grid.Column="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="Tùy chọn chạy" Style="{StaticResource H2}"/>
                    <CheckBox IsChecked="{Binding S.MultiThread}" Margin="0,0,0,8">
                        <TextBlock><Run Text="Chạy đa luồng"/><Run Text=" (Worker = số CPU − 2)" Foreground="{StaticResource Muted}"/></TextBlock>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding S.Resume}" Margin="0,0,0,8">
                        <TextBlock><Run Text="Resume Job"/><Run Text=" (tiếp tục khi lỗi/dừng)" Foreground="{StaticResource Muted}"/></TextBlock>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding S.AuditLog}" Margin="0,0,0,8">
                        <TextBlock><Run Text="Ghi Audit Log"/><Run Text=" (job.log)" Foreground="{StaticResource Muted}"/></TextBlock>
                    </CheckBox>
                    <CheckBox IsChecked="{Binding S.SkipErrors}">
                        <TextBlock><Run Text="Bỏ qua hồ sơ lỗi"/><Run Text=" (không dừng cả mẻ)" Foreground="{StaticResource Muted}"/></TextBlock>
                    </CheckBox>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tiến trình -->
        <StackPanel Grid.Row="1" Margin="0,14,0,0">
            <Grid Margin="0,0,0,4">
                <TextBlock Text="{Binding ProgressText}" Foreground="{StaticResource Muted}"/>
                <TextBlock Text="{Binding DoneText}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
            </Grid>
            <ProgressBar Height="12" Minimum="0" Maximum="{Binding ProgressMax}" Value="{Binding ProgressValue}"
                         Foreground="{StaticResource Accent}"/>
            <StackPanel Orientation="Horizontal" Margin="0,10,0,4">
                <Button Style="{StaticResource GhostButton}"
                        Command="{Binding OpenOutputFolderCommand}"
                        Visibility="{Binding CanOpenFolder, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE838;" FontFamily="Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Mở thư mục kết quả" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
            <TextBlock Text="Nhật ký (realtime)" FontWeight="SemiBold" Margin="0,4,0,4"/>
        </StackPanel>

        <!-- Cửa sổ log nền đen -->
        <Border Grid.Row="2" Background="#FF1B1B1B" BorderBrush="#FF333333" BorderThickness="1" CornerRadius="4">
            <ListBox x:Name="LogList" ItemsSource="{Binding LogLines}" Background="Transparent" BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}" Foreground="{Binding Color}" FontFamily="Consolas" FontSize="13.5"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Foreground" Value="#FFD4D4D4"/>
                        <Setter Property="Padding" Value="4,1"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>
    </Grid>
</UserControl>
