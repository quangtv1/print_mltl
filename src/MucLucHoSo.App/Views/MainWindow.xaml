<Window x:Class="MucLucHoSo.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MucLucHoSo.App.ViewModels"
        xmlns:v="clr-namespace:MucLucHoSo.App.Views"
        Title="Tạo mục lục hồ sơ - SaoMai" Height="820" Width="1280" MinWidth="1060" MinHeight="660"
        FontFamily="Segoe UI" FontSize="14" Background="{StaticResource Panel}">
    <!-- Phím tắt điều hướng wizard: Alt ← quay lại, Alt → tiếp theo -->
    <Window.InputBindings>
        <KeyBinding Modifiers="Alt" Key="Left" Command="{Binding BackCommand}"/>
        <KeyBinding Modifiers="Alt" Key="Right" Command="{Binding NextCommand}"/>
    </Window.InputBindings>
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:Step1SourceViewModel}"><v:Step1SourceView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:Step2MappingViewModel}"><v:Step2MappingView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:Step3PreviewViewModel}"><v:Step3PreviewView/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:Step4GenerateViewModel}"><v:Step4GenerateView/></DataTemplate>

        <!-- Một mục trong thanh bước -->
        <DataTemplate x:Key="StepHeaderItem" DataType="{x:Type vm:StepViewModel}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,5,0">
                <Border x:Name="dot" Width="27" Height="27" CornerRadius="13.5" Background="#FFE1E6EE" Margin="0,0,8,0">
                    <Grid>
                        <TextBlock x:Name="num" Text="{Binding Number}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{StaticResource Muted}" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock x:Name="chk" Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="White"
                                   FontSize="12" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                    </Grid>
                </Border>
                <StackPanel VerticalAlignment="Center" Margin="0,0,11,0">
                    <TextBlock x:Name="kicker" FontSize="10" Foreground="{StaticResource Muted}">
                        <Run Text="BƯỚC "/><Run Text="{Binding Number, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock x:Name="title" Text="{Binding Title}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{StaticResource Muted}"/>
                </StackPanel>
                <TextBlock x:Name="chev" Text="&#xE76C;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                           Foreground="{StaticResource Line}" VerticalAlignment="Center" Margin="0,0,8,0"/>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter TargetName="dot" Property="Background" Value="{StaticResource Accent}"/>
                    <Setter TargetName="num" Property="Foreground" Value="White"/>
                    <Setter TargetName="title" Property="Foreground" Value="{StaticResource Ink}"/>
                    <Setter TargetName="kicker" Property="Foreground" Value="{StaticResource Accent}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter TargetName="dot" Property="Background" Value="{StaticResource Ok}"/>
                    <Setter TargetName="num" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="chk" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="title" Property="Foreground" Value="{StaticResource Ink}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Number}" Value="4">
                    <Setter TargetName="chev" Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Thanh bước (dải trắng trên cùng) -->
        <Border Grid.Row="0" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="15,10">
            <ItemsControl ItemsSource="{Binding Steps}" ItemTemplate="{StaticResource StepHeaderItem}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </Border>

        <!-- Nội dung bước (trên nền xám) -->
        <ContentControl Grid.Row="1" Content="{Binding CurrentStep}"/>

        <!-- Thanh dưới -->
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="18,12">
            <Grid>
                <TextBlock VerticalAlignment="Center" Foreground="{StaticResource Muted}" FontSize="14">
                    <Run Text="Bước "/><Run Text="{Binding CurrentStep.Number, Mode=OneWay}"/><Run Text="/4 — "/><Run Text="{Binding CurrentStep.Description, Mode=OneWay}"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="◀  Quay lại" Style="{StaticResource GhostButton}" Command="{Binding BackCommand}"/>
                    <Button Content="Tiếp theo  ▶" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                            Command="{Binding NextCommand}"
                            Visibility="{Binding IsLastStep, Converter={StaticResource InverseBoolToVis}}"/>
                    <Button Content="{Binding CurrentStep.PrimaryLabel}" Style="{StaticResource PrimaryButton}" Margin="10,0,0,0"
                            Background="{Binding CurrentStep.PrimaryBackground}"
                            Command="{Binding CurrentStep.PrimaryCommand}"
                            Visibility="{Binding IsLastStep, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
