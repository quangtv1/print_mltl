<Window x:Class="MucLucHoSo.App.Views.FullscreenPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" WindowState="Maximized" ResizeMode="NoResize"
        ShowInTaskbar="False" Background="#FF1B1B1B" WindowStartupLocation="CenterScreen"
        Title="Xem toàn màn hình">
    <Window.Resources>
        <!-- Mũi tên đổi hồ sơ: nền trong suốt, chữ đậm + sáng hơn khi rê chuột -->
        <Style x:Key="FsArrow" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#FFBFBFBF"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    <Grid x:Name="Root">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Thanh trên: tên hồ sơ + hướng dẫn + nút thoát -->
        <Border Grid.Row="0" Background="#DD000000" Padding="16,8">
            <Grid>
                <TextBlock Text="{Binding NavText}" Foreground="White" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="&#x2190;" Style="{StaticResource FsArrow}" Click="OnPrevClick"
                            ToolTip="Hồ sơ trước (←)" AutomationProperties.Name="Hồ sơ trước"/>
                    <TextBlock Foreground="#FFCFCFCF" VerticalAlignment="Center" Margin="8,0"
                               Text="Esc để thoát  ·  bấm mũi tên đổi hồ sơ"/>
                    <Button Content="&#x2192;" Style="{StaticResource FsArrow}" Click="OnNextClick"
                            ToolTip="Hồ sơ sau (→)" AutomationProperties.Name="Hồ sơ sau"/>
                </StackPanel>
                <Button Content="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="14" HorizontalAlignment="Right"
                        Foreground="White" Background="Transparent" BorderThickness="0" Width="34" Height="30"
                        Cursor="Hand" Click="OnCloseClick" ToolTip="Thoát (Esc)" AutomationProperties.Name="Thoát toàn màn hình"/>
            </Grid>
        </Border>

        <!-- Ảnh render: fit vào vùng còn lại, giữ nguyên tỉ lệ (Uniform); nhiều trang thì cuộn dọc -->
        <ScrollViewer Grid.Row="1" x:Name="Viewport" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding PreviewPages}" HorizontalAlignment="Center" Margin="0,12">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" Margin="0,8" SnapsToDevicePixels="True">
                            <!-- Trừ lề (ItemsControl 0,12 + Border 0,8 = 40 dọc) để 1 trang fit trọn, không sinh thanh cuộn -->
                            <Image Source="{Binding}" Stretch="Uniform"
                                   MaxWidth="{Binding ActualWidth, ElementName=Viewport, Converter={StaticResource Subtract}, ConverterParameter=24}"
                                   MaxHeight="{Binding ActualHeight, ElementName=Viewport, Converter={StaticResource Subtract}, ConverterParameter=40}"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
