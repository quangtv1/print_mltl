<UserControl x:Class="MucLucHoSo.App.Views.Step2MappingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== CỘT TRÁI (1/3): Cột gom nhóm + Kiểm tra dữ liệu ===== -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Block: Cột gom nhóm -->
            <Border Grid.Row="0" Background="#FFEFF4FC" BorderBrush="#FFCADCF5" BorderThickness="1" CornerRadius="10" Padding="14,12">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="15" Foreground="{StaticResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Cột gom nhóm hồ sơ" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="(mỗi hồ sơ 1 file)" Foreground="{StaticResource Muted}" Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding S.Headers}" SelectedItem="{Binding S.GroupColumn}"/>
                    <TextBlock Text="{Binding FileEstimateText}" Margin="0,8,0,0" Foreground="{StaticResource Accent}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Block: Kiểm tra dữ liệu -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="14">
                <StackPanel>
                    <TextBlock Text="Kiểm tra dữ liệu" Style="{StaticResource H2}"/>
                    <Button Content="✔  Chạy kiểm tra (Validation)" Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Stretch" Command="{Binding ValidateCommand}" Margin="0,0,0,10"/>
                    <ProgressBar Height="6" IsIndeterminate="True" Margin="0,0,0,10"
                                 Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}"/>
                    <Border CornerRadius="6" Padding="10,8" Visibility="{Binding ValidationText, Converter={StaticResource NullToVis}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource Panel}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ValidationIsOk}" Value="True">
                                        <Setter Property="Background" Value="#FFEFF9F2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ValidationText}" FontFamily="Consolas" FontSize="12.5" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== CỘT PHẢI (2/3): Bảng ghép biến ===== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,8">
                <TextBlock Text="Ghép biến trong mẫu ↔ cột trong file Excel" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding MappedCountText}" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource Warn}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding BindStatusIsOk}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Ok}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                <DockPanel>
                    <!-- Header bảng: chừa sẵn 16px cho thanh cuộn để thẳng cột với các dòng -->
                    <Grid DockPanel.Dock="Top" Background="{StaticResource Panel}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="52"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="40"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="110"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0" Padding="12,10"><TextBlock Text="#" FontWeight="SemiBold" Foreground="{StaticResource Muted}"/></Border>
                                <Border Grid.Column="1" Padding="12,10"><TextBlock Text="Cột trong Excel (header)" FontWeight="SemiBold" Foreground="{StaticResource Muted}"/></Border>
                                <Border Grid.Column="2" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0"/>
                                <Border Grid.Column="3" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0" Padding="12,10"><TextBlock Text="Biến trong mẫu" FontWeight="SemiBold" Foreground="{StaticResource Muted}"/></Border>
                                <Border Grid.Column="4" Padding="12,10"><TextBlock Text="Tự khớp" FontWeight="SemiBold" Foreground="{StaticResource Muted}"/></Border>
                            </Grid>
                        </Border>
                    </Grid>

                    <ScrollViewer VerticalScrollBarVisibility="Visible">
                        <ItemsControl ItemsSource="{Binding S.Bindings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="52"/>
                                                <ColumnDefinition Width="1.5*"/>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="1*"/>
                                                <ColumnDefinition Width="110"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Grid.Column="0" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0" Padding="12,8">
                                                <TextBlock Text="{Binding Index}" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
                                            </Border>
                                            <Border Grid.Column="1" Padding="10,6">
                                                <ComboBox IsEditable="True"
                                                          ItemsSource="{Binding AvailableColumns}"
                                                          Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                                                          IsEnabled="{Binding IsAutoField, Converter={StaticResource InverseBool}}"/>
                                            </Border>
                                            <Border Grid.Column="2" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0">
                                                <TextBlock Text="→" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
                                            </Border>
                                            <Border Grid.Column="3" BorderBrush="{StaticResource Line}" BorderThickness="0,0,1,0" Padding="12,8">
                                                <TextBlock VerticalAlignment="Center" FontFamily="Consolas" FontSize="14" Foreground="{StaticResource Accent}"
                                                           Text="{Binding Variable, StringFormat={}{{{0}}}}"/>
                                            </Border>
                                            <Border Grid.Column="4" Padding="12,8">
                                                <TextBlock Text="{Binding MatchText}" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource Muted}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding MatchOk}" Value="True">
                                                                    <Setter Property="Foreground" Value="{StaticResource Ok}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
