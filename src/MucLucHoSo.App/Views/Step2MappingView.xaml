<UserControl x:Class="MucLucHoSo.App.Views.Step2MappingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- ===== CỘT TRÁI (1/3): Cột gom nhóm + Kiểm tra dữ liệu ===== -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="14"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Block: Cột gom nhóm — quan trọng nhưng dịu lại (chỉ nền, không viền đậm) -->
            <Border Grid.Row="0" Background="#FFEFF3FA" CornerRadius="10" Padding="16,14">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="18" Foreground="{StaticResource Accent}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Cột gom nhóm hồ sơ" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource Accent}" CornerRadius="9" Padding="7,1" Margin="8,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="BẮT BUỘC" FontSize="10.5" FontWeight="SemiBold" Foreground="White"/>
                        </Border>
                    </StackPanel>
                    <ComboBox Height="38" FontSize="14" ItemsSource="{Binding S.Headers}" SelectedItem="{Binding S.GroupColumn}"/>
                    <TextBlock Text="Mỗi giá trị khác nhau của cột này = 1 file mục lục. Chọn sai cột → gom nhóm sai, kết quả không như mong muốn."
                               Foreground="{StaticResource Muted}" FontSize="12.5" TextWrapping="Wrap" Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <!-- Block: Kiểm tra dữ liệu -->
            <Border Grid.Row="2" Style="{StaticResource Card}" Padding="14">
                <StackPanel>
                    <TextBlock Text="Kiểm tra dữ liệu" Style="{StaticResource H2}"/>
                    <Button Content="✔  Chạy kiểm tra (Validation)" Style="{StaticResource GhostButton}"
                            HorizontalAlignment="Stretch" Command="{Binding ValidateCommand}" Margin="0,0,0,10"/>
                    <ProgressBar Height="6" IsIndeterminate="True" Margin="0,0,0,10"
                                 Visibility="{Binding Busy, Converter={StaticResource BoolToVis}}"/>
                    <Border CornerRadius="6" Padding="10,8" Visibility="{Binding ValidationText, Converter={StaticResource NullToVis}}">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="{StaticResource Panel}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ValidationIsOk}" Value="True">
                                        <Setter Property="Background" Value="#FFEFF3FA"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding ValidationText}" FontFamily="Consolas" FontSize="12.5" TextWrapping="Wrap"/>
                    </Border>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ===== CỘT PHẢI (2/3): Bảng ghép biến ===== -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="2,0,0,8">
                <TextBlock Text="Ghép biến trong mẫu ↔ cột trong file Excel" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource Ink}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding MappedCountText}" FontWeight="SemiBold" Margin="6,0,0,0" VerticalAlignment="Center">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource Warn}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding BindStatusIsOk}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource Ok}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </StackPanel>

            <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
                <DockPanel>
                    <!-- Tiêu đề cột (chừa 16px bên phải cho thanh cuộn để thẳng hàng) -->
                    <Border DockPanel.Dock="Top" Background="{StaticResource Panel}" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="0,10">
                        <Grid Margin="0,0,16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2"/>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="132"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="1" Text="Biến trong mẫu" FontWeight="SemiBold" Foreground="{StaticResource Muted}" Margin="14,0,0,0"/>
                            <TextBlock Grid.Column="2" Text="Nguồn: cột Excel hoặc hằng" FontWeight="SemiBold" Foreground="{StaticResource Muted}" Margin="8,0,0,0"/>
                            <TextBlock Grid.Column="3" Text="Trạng thái" FontWeight="SemiBold" Foreground="{StaticResource Muted}"/>
                        </Grid>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding S.Bindings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                                        <Grid MinHeight="40">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2"/>
                                                <ColumnDefinition Width="220"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="132"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Thanh màu theo loại biến (hồ sơ / bảng / tự động) -->
                                            <Border Grid.Column="0">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRowField}" Value="True"><Setter Property="Background" Value="#FF7A3FF2"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding IsAutoField}" Value="True"><Setter Property="Background" Value="{StaticResource Ok}"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                            </Border>

                                            <!-- Biến (loại phân biệt bằng thanh màu bên trái) -->
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="14,0"
                                                       Text="{Binding Variable, StringFormat={}{{{0}}}}" FontFamily="Consolas" FontSize="14"
                                                       Foreground="{StaticResource Accent}" TextTrimming="CharacterEllipsis"/>

                                            <!-- Nguồn: combo (cột/hằng) hoặc ghi chú tự động -->
                                            <Grid Grid.Column="2" Margin="8,4,12,4" VerticalAlignment="Center">
                                                <Grid Visibility="{Binding IsAutoField, Converter={StaticResource InverseBoolToVis}}">
                                                    <ComboBox IsEditable="True" ItemsSource="{Binding AvailableColumns}"
                                                              Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"/>
                                                    <TextBlock Text="Chọn cột hoặc gõ hằng…" Foreground="{StaticResource Muted}" FontStyle="Italic"
                                                               Margin="12,0,34,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                                               Visibility="{Binding Value, Converter={StaticResource NullToVis}, ConverterParameter=invert}"/>
                                                </Grid>
                                                <TextBlock Text="Word tự tính khi render (PAGE/NUMPAGES)" Foreground="{StaticResource Muted}" FontStyle="Italic"
                                                           VerticalAlignment="Center" Margin="2,0,0,0"
                                                           Visibility="{Binding IsAutoField, Converter={StaticResource BoolToVis}}"/>
                                            </Grid>

                                            <!-- Trạng thái (pill) -->
                                            <Border Grid.Column="3" HorizontalAlignment="Left" VerticalAlignment="Center" CornerRadius="10" Padding="10,3">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#FFFBEACF"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBound}" Value="True"><Setter Property="Background" Value="#FFE3ECFA"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding IsColumn}" Value="True"><Setter Property="Background" Value="#FFDDF1E5"/></DataTrigger>
                                                            <DataTrigger Binding="{Binding IsAutoField}" Value="True"><Setter Property="Background" Value="#FFDDF1E5"/></DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock FontSize="12.5" FontWeight="SemiBold">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Text" Value="Chưa gán"/>
                                                            <Setter Property="Foreground" Value="{StaticResource Warn}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsBound}" Value="True"><Setter Property="Text" Value="Hằng"/><Setter Property="Foreground" Value="{StaticResource Accent}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding IsColumn}" Value="True"><Setter Property="Text" Value="✓ Cột"/><Setter Property="Foreground" Value="{StaticResource OkText}"/></DataTrigger>
                                                                <DataTrigger Binding="{Binding IsAutoField}" Value="True"><Setter Property="Text" Value="Tự động"/><Setter Property="Foreground" Value="{StaticResource OkText}"/></DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
