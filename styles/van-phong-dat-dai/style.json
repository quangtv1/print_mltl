  "template_html": "<table border=\"0\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\">\n<tr>\n<td width=\"50%\" align=\"center\">{co_quan_dong1}<br/><b><u>{co_quan_dong2}</u></b></td>\n<td width=\"50%\" align=\"center\">CỘNG HÒA XÃ HỘI CHỦ NGHĨA VIỆT NAM<br/><b><u>Độc lập - Tự do - Hạnh phúc</u></b></td>\n</tr>\n</table>\n<p align=\"center\"><span style=\"font-size:15pt\"><b>{tieu_de}</b></span></p>\n<p align=\"center\"><i>Số, ký hiệu hồ sơ (đơn vị bảo quản): {ho_so_so}</i></p>\n<table border=\"1\" width=\"100%\" cellspacing=\"0\" cellpadding=\"3\">\n<tr><td width=\"7%\" align=\"center\"><b>STT</b></td><td width=\"12%\" align=\"center\"><b>Số, ký hiệu văn bản</b></td><td width=\"13%\" align=\"center\"><b>Ngày tháng văn bản</b></td><td width=\"22%\" align=\"center\"><b>Tác giả</b></td><td width=\"28%\" align=\"center\"><b>Trích yếu nội dung VB</b></td><td width=\"8%\" align=\"center\"><b>Tờ số</b></td><td width=\"8%\" align=\"center\"><b>Ghi chú</b></td></tr>\n<tr><td width=\"7%\" align=\"center\">{stt}</td><td width=\"12%\" align=\"center\">{so_ky_hieu_vb}</td><td width=\"13%\" align=\"center\">{ngay_thang_vb}</td><td width=\"22%\" align=\"center\">{tac_gia}</td><td width=\"28%\" align=\"left\">{trich_yeu}</td><td width=\"8%\" align=\"center\">{to_so}</td><td width=\"8%\" align=\"center\">{ghi_chu}</td></tr>\n</table>\n<p></p>\n<table border=\"0\" width=\"100%\" cellspacing=\"0\" cellpadding=\"0\">\n<tr>\n<td width=\"55%\"></td>\n<td width=\"45%\" align=\"center\"><b>{chuc_danh_ky}</b><br/><br/><br/><br/><b>{nguoi_ky}</b></td>\n</tr>\n</table>",
  "document_fields": {
    "ho_so_so": "Hồ sơ số"
  },
  "row_mapping": {
    "stt": "STT",
    "so_ky_hieu_vb": "Số, ký hiệu văn bản",
