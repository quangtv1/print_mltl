{
  "name": "Văn phòng đăng ký đất đai - Đông Hà",
  "template_file": "template.docx",
  "grouping_column": "Tiêu đề hồ sơ",
  "output_filename_pattern": "MLHS_{ho_so_so}.pdf",
  "settings": {
